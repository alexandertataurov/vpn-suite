{
  "title": "VPN Suite - Infrastructure Overview",
  "uid": "vpn-suite-infra",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["vpn-suite", "observability"],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "5s",
  "liveNow": false,
  "timepicker": {"refresh_intervals": ["5s", "10s", "30s", "1m", "5m"]},
  "panels": [
    {"type": "stat", "title": "Targets Up", "gridPos": {"x": 0, "y": 0, "w": 4, "h": 3}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "count(up==1)", "refId": "A"}]},
    {"type": "stat", "title": "Targets Down", "gridPos": {"x": 4, "y": 0, "w": 4, "h": 3}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "count(up==0)", "refId": "A"}]},
    {"type": "timeseries", "title": "CPU % by instance", "gridPos": {"x": 0, "y": 3, "w": 12, "h": 6}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Memory % by instance", "gridPos": {"x": 12, "y": 3, "w": 12, "h": 6}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "{{instance}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Up by job", "gridPos": {"x": 0, "y": 9, "w": 24, "h": 6}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum(up) by (job)", "legendFormat": "{{job}}", "refId": "A"}]},
    {"type": "stat", "title": "Postgres Connections", "gridPos": {"x": 0, "y": 15, "w": 6, "h": 3}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "pg_stat_database_numbackends", "refId": "A"}]},
    {"type": "stat", "title": "Redis Memory", "gridPos": {"x": 6, "y": 15, "w": 6, "h": 3}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "redis_memory_used_bytes", "refId": "A"}]},
    {"type": "timeseries", "title": "Postgres Transaction Rate", "gridPos": {"x": 0, "y": 18, "w": 12, "h": 6}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum(rate(pg_stat_database_xact_commit[5m]))", "legendFormat": "Commits", "refId": "A"}, {"expr": "sum(rate(pg_stat_database_xact_rollback[5m]))", "legendFormat": "Rollbacks", "refId": "B"}]},
    {"type": "timeseries", "title": "Redis Commands/sec", "gridPos": {"x": 12, "y": 18, "w": 12, "h": 6}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "Commands", "refId": "A"}]}
  ]
}
