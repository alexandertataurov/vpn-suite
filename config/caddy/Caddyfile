# Reverse proxy for VPN Admin API.
# Set PUBLIC_DOMAIN env var (docker-compose) to define the external hostname.
# HTTPS via Let's Encrypt (automatic when DNS points to this host, ports 80/443 open)
# Disable HTTP/3 (QUIC) to avoid ERR_QUIC_PROTOCOL_ERROR in some clients (e.g. Edge behind proxy/firewall)
# TLS: Caddy default is TLS 1.2+. To enforce explicitly add: tls { protocols tls1.2 tls1.3 } in site blocks.
# X-Request-ID: forwarded from client or generated for correlation with app logs.
{
	admin off
	servers {
		protocols h1 h2
	}
}

# Healthcheck and local API access: Docker hits 127.0.0.1:80/health; /api/* proxied to admin-api.
http://127.0.0.1, http://localhost {
	route {
		handle /health {
			reverse_proxy admin-api:8000
		}
		handle /api/* {
			reverse_proxy admin-api:8000
		}
		handle {
			respond 404
		}
	}
}

# Same-stack agent: CONTROL_PLANE_URL=https://reverse-proxy:8443 (Docker network).
reverse-proxy:8443 {
	tls internal {
		client_auth {
			mode require_and_verify
			trust_pool file /etc/caddy/agent_ca.pem
		}
	}
	handle /api/v1/agent/* {
		reverse_proxy admin-api:8000
	}
	handle {
		respond 404
	}
}

# Dedicated agent endpoint with mTLS on a separate port (does not require a separate DNS record).
# Node-agent uses CONTROL_PLANE_URL=https://<PUBLIC_DOMAIN>:8443
{$PUBLIC_DOMAIN}:8443 {
	# Caddy terminates TLS and verifies client certificates against /etc/caddy/agent_ca.pem.
	tls {
		protocols tls1.2 tls1.3
		client_auth {
			mode require_and_verify
			trust_pool file /etc/caddy/agent_ca.pem
		}
	}
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
	}

	# Optional: restrict agent access by source IP/CIDR (in addition to mTLS).
	# Set AGENT_ALLOW_CIDRS to a space-separated list, e.g. "203.0.113.10/32 198.51.100.0/24".
	@agent_allowed {
		remote_ip {$AGENT_ALLOW_CIDRS}
	}

	# Only agent API is exposed on this port.
	handle @agent_allowed {
		handle /api/v1/agent/* {
			reverse_proxy admin-api:8000
		}
		handle {
			respond 404
		}
	}
	handle {
		respond 403
	}
}

# route block enforces order (Caddy otherwise sorts: handle before reverse_proxy, so / would win and file_server 404s /api/*)
{$PUBLIC_DOMAIN} {
	tls {
		protocols tls1.2 tls1.3
	}
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
	}
	route {
		handle /api/* {
			reverse_proxy admin-api:8000
		}
		handle / {
			handle_path / {
				root * /srv/root
				try_files {path} /index.html
				file_server
			}
		}
		handle /admin {
			redir /admin /admin/ 308
		}
		# Admin SPA: run `./manage.sh build-admin` before up-core so frontend/admin/dist has assets.
		# Static assets: serve directly (no try_files), avoid wrong MIME on 404
		handle /admin/assets/* {
			handle_path /admin/* {
				root * /srv/admin
				header Cache-Control "public, max-age=31536000, immutable"
				file_server
			}
		}
		handle /admin/* {
			header Cache-Control "no-cache, no-store, must-revalidate"
			handle_path /admin/* {
				root * /srv/admin
				try_files {path} /index.html
				file_server
			}
		}
		handle /storybook {
			redir /storybook /storybook/ 308
		}
		handle /storybook/* {
			header Cache-Control "no-store, no-cache, must-revalidate"
			handle_path /storybook/* {
				root * /srv/storybook
				# Do not fallback to index.html for static assets — Storybook expects JSON, gets HTML → SyntaxError
				@static path *.json *.js *.css *.map *.ico *.svg *.woff2 *.woff *.html
				handle @static {
					file_server
				}
				handle {
					try_files {path} /index.html
					file_server
				}
			}
		}
		handle /webapp {
			redir /webapp /webapp/ 308
		}
		handle /webapp/* {
			header Content-Security-Policy "frame-ancestors 'self' https://web.telegram.org https://*.telegram.org"
			handle_path /webapp/* {
				root * /srv/webapp
				try_files {path} /index.html
				file_server
			}
		}
		handle {
			header X-Frame-Options "DENY"
			reverse_proxy admin-api:8000
		}
	}
}
