{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmitOnError": true
  },
  "include": ["lib/**/*.ts", "obsidian-mcp/**/*.ts", "filesystem-mcp/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
