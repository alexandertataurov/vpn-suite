# VPN Suite — Single env template. Copy to .env and fill values.
# See docs/REQUIRED_SECRETS.md for required vars by context.

# --- REQUIRED (always) ---
# Reverse-proxy hostname
PUBLIC_DOMAIN=localhost
# Postgres password (docker-compose)
POSTGRES_PASSWORD=postgres
# Grafana (monitoring profile)
GRAFANA_ADMIN_PASSWORD=admin

# --- Core ---
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/vpn_admin
REDIS_URL=redis://redis:6379/0
# Production: set REDIS_PASSWORD and use REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# REDIS_PASSWORD=
SECRET_KEY=dev-secret-change-me
POSTGRES_USER=postgres
POSTGRES_DB=vpn_admin

# --- Admin bootstrap ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin

# --- REQUIRED in production (operator confirm tokens) ---
# BAN_CONFIRM_TOKEN=
# REVOKE_CONFIRM_TOKEN=
# BLOCK_CONFIRM_TOKEN=
# RESTART_CONFIRM_TOKEN=
# CLEANUP_DB_CONFIRM_TOKEN=

# --- Optional ---
AGENT_ALLOW_CIDRS=
# Comma-separated origins for CORS (e.g. https://your-domain.com). Required if miniapp is on a different origin than the API. In development, localhost:5175 is allowed when empty.
CORS_ALLOW_ORIGINS=
# Dangerous settings controls in Admin.
APP_ENV_EDITOR_ENABLED=0
NODE_MODE=mock
# When true (default): if add_peer fails in NODE_MODE=real, keep device and return config (PENDING_APPLY; node-agent can add peer later).
ISSUE_FALLBACK_ON_PEER_FAILURE=true
NODE_DISCOVERY=agent
# Outline VPN is unsupported (FEATURE_OUTLINE_LEGACY=false). Use AmneziaWG + node-agent only.
AGENT_SHARED_TOKEN=
AGENT_SERVER_ID=vpn-node-1
AGENT_HEARTBEAT_TTL_SECONDS=120
# Node-agent needs host docker group GID to access /var/run/docker.sock. Auto-detected if unset (getent group docker).
DOCKER_GID=119
GRAFANA_ADMIN_USER=admin
ADMIN_API_IP=
DOCKER_TELEMETRY_HOSTS_JSON=
DOCKER_TELEMETRY_REQUEST_TIMEOUT_SECONDS=20
# Required for dashboard data. Use http://prometheus:9090 (Docker service name, not 127.0.0.1). Empty = dashboard shows "API DEGRADED" / "No data". Set when using --profile monitoring.
TELEMETRY_PROMETHEUS_URL=
# OTLP traces endpoint (e.g. otel-collector:4317). Empty = tracing disabled. Set when using monitoring profile.
OTEL_TRACES_ENDPOINT=
# Admin frontend telemetry ingest controls.
ADMIN_TELEMETRY_EVENTS_ENABLED=1
ADMIN_TELEMETRY_SAMPLE_RATE=1.0
# Host port for local Prometheus UI; use non-9090 on hosts where another Prometheus already binds 9090.
PROMETHEUS_HOST_PORT=19090
# Remote wg-exporter targets (multi-host). JSON array: [{"host":"10.0.0.5","port":9586,"node_id":"vpn-1","server_id":"srv-1"}]
# DISCOVERY_REMOTE_WG_EXPORTERS=

# Reconciliation: remove orphan peers (on node but not in DB) before add. When false, add_peer can fail with allowed_ips conflict.
# RECONCILIATION_REMOVE_ORPHANS=true

# --- Bot (required if running bot) ---
BOT_TOKEN=
BOT_API_KEY=
VITE_TELEGRAM_BOT_USERNAME=
SUPPORT_HANDLE=@support

# --- Optional ---
BOT_TOKEN_AUDIT=
VITE_TELEGRAM_BOT_USERNAME_AUDIT=
TELEGRAM_STARS_WEBHOOK_SECRET=
# VITE_API_BASE_URL=
# VITE_ADMIN_BASE=/admin
# PLAN_1_NAME= PLAN_1_DURATION_DAYS= PLAN_1_PRICE_STARS= PLAN_1_PRICE_CURRENCY=XTR
