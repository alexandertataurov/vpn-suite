# VPN Suite — Single env template. Copy to .env and fill values.
# See docs/ops/required-secrets.md for required vars by context.
# Never commit real .env (gitignored).

# --- REQUIRED (always) ---
PUBLIC_DOMAIN=localhost
POSTGRES_PASSWORD=postgres
GRAFANA_ADMIN_PASSWORD=change-me
ALERTMANAGER_IMAGE=prom/alertmanager:v0.27.0

# --- Core ---
ENVIRONMENT=production
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/vpn_admin
REDIS_URL=redis://redis:6379/0
# Production: set REDIS_PASSWORD and use REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# REDIS_PASSWORD=
SECRET_KEY=change-me
POSTGRES_USER=postgres
POSTGRES_DB=vpn_admin

# --- Admin bootstrap ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- REQUIRED in production (admin confirm tokens for destructive actions) ---
BAN_CONFIRM_TOKEN=
REVOKE_CONFIRM_TOKEN=
BLOCK_CONFIRM_TOKEN=
RESTART_CONFIRM_TOKEN=
CLEANUP_DB_CONFIRM_TOKEN=
DELETE_USER_CONFIRM_TOKEN=

# --- API / CORS / VPN ---
# Uvicorn workers (admin-api). Default in Dockerfile/entrypoint: 2.
# WEB_CONCURRENCY=2
# Comma-separated origins (miniapp/admin local dev: include http://localhost:5174,5175).
CORS_ALLOW_ORIGINS=
# Host clients use for AmneziaWG endpoint (Issue Config); optional.
VPN_DEFAULT_HOST=

# --- Node mode & agent ---
NODE_MODE=agent
NODE_DISCOVERY=agent
AGENT_SHARED_TOKEN=
AGENT_HEARTBEAT_TTL_SECONDS=120
AGENT_ALLOW_CIDRS=0.0.0.0/0 ::/0
CONTROL_PLANE_URL=https://reverse-proxy:8443
REQUIRE_MTLS=1
TLS_INSECURE_SKIP_VERIFY=0
AGENT_SERVER_ID=vpn-node-1
AGENT_CONTAINER_FILTER=auto
AGENT_INTERFACE_NAME=awg0
DOCKER_GID=119

# --- Grafana ---
GRAFANA_ADMIN_USER=admin

# --- Docker telemetry & observability ---
DOCKER_TELEMETRY_HOSTS_JSON=
DOCKER_TELEMETRY_REQUEST_TIMEOUT_SECONDS=20
TELEMETRY_PROMETHEUS_URL=
OTEL_TRACES_ENDPOINT=
TELEMETRY_LOKI_URL=
PROMETHEUS_HOST_PORT=19090
VICTORIA_METRICS_IMAGE=victoriametrics/victoria-metrics:v1.97.1
TEMPO_IMAGE=grafana/tempo:2.3.1
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.91.0
AWS_CLI_IMAGE=amazon/aws-cli:2
# DISCOVERY_REMOTE_WG_EXPORTERS=
NODE_TELEMETRY_INTERVAL_SECONDS=30
NODE_TELEMETRY_CACHE_TTL_SECONDS=60

# --- Bot (required if running bot) ---
BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
BOT_API_KEY=
# Bot @username without @. Compose passes this to admin-api (TELEGRAM_BOT_USERNAME).
VITE_TELEGRAM_BOT_USERNAME=
SUPPORT_HANDLE=@support
SUPPORT_LINK=
PANEL_URL=http://admin-api:8000
INSTRUCTION_TEXT=
INSTALL_GUIDE_URL=
BOT_WEBHOOK_URL=
BOT_WEBHOOK_PATH=/bot-webhook
TELEGRAM_STARS_WEBHOOK_SECRET=
REFERRAL_REWARD_BONUS_DAYS=7
TRIAL_DURATION_HOURS=24
RETENTION_DISCOUNT_PERCENT=20
CONFIG_REGEN_DAILY_CAP=5

# --- Bot audit (optional) ---
BOT_TOKEN_AUDIT=
VITE_TELEGRAM_BOT_USERNAME_AUDIT=

# --- Alerting (Alertmanager) ---
# ALERTMANAGER_SLACK_WEBHOOK_URL=
# ALERTMANAGER_SLACK_CHANNEL_CRITICAL=#alerts-critical
# ALERTMANAGER_SLACK_CHANNEL_WARNING=#alerts
ALERTMANAGER_TELEGRAM_BOT_TOKEN=
ALERTMANAGER_TELEGRAM_CHAT_ID=

# --- Resource limits (optional; tuned for ~6GB) ---
# CPU_TINY=0.1 MEM_TINY=64m CPU_SMALL=0.2 MEM_SMALL=192m CPU_MEDIUM=0.5 MEM_MEDIUM=384m CPU_LARGE=1.0 MEM_LARGE=768m
# PROMETHEUS_RETENTION=15d

# --- Grace period (spec v2) ---
# GRACE_WINDOW_HOURS=24

# --- Product analytics & RUM ---
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
# VITE_FARO_COLLECTOR_URL=
# VITE_ANALYTICS_ENABLED=1

# --- MCP (Cursor AI tools) ---
# CONTEXT7_API_KEY=
# GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Optional backend overrides ---
# RECONCILE_READ_ONLY=0
# ADMIN_API_IP=
# LOG_JSON=true
# LOGIN_RATE_LIMIT=10
# API_RATE_LIMIT_PER_MINUTE=200

# --- Optional frontend (Vite: admin + miniapp) ---
# API root must include /api/v1. Omit for local dev when using Vite /api proxy to localhost:8000.
# VITE_API_BASE_URL=https://your-public-domain.example/api/v1
# VITE_ADMIN_BASE=/admin
# VITE_APP_VERSION=1.0.0
# VITE_BUILD_ID=local
# VITE_BUILD_VERSION=
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENV=development
# VITE_SENTRY_RELEASE=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0
# VITE_SENTRY_SOURCEMAPS=0
# VITE_WEB_VITALS_ENABLED=0
# VITE_BUILD_HASH=

# Plans: managed in Admin UI / DB. Optional: seed-plans with PLAN_1_* … PLAN_10_*.
