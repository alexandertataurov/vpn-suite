# Node Agent — copy to .env and set values. Run on the host that has AmneziaWG container(s).

# Required: control plane agent endpoint (mTLS port)
CONTROL_PLANE_URL=https://vpn.vega.llc:8443

# Required: server id from control plane (run: ./manage.sh seed-agent-server)
SERVER_ID=vpn-node-1

# Required: must match control plane AGENT_SHARED_TOKEN
AGENT_SHARED_TOKEN=

# mTLS (required for CONTROL_PLANE_URL :8443). Generate with: ../scripts/generate-agent-client-cert.sh
MTLS_CERT_FILE=/app/secrets/agent_client_cert.pem
MTLS_KEY_FILE=/app/secrets/agent_client_key.pem
MTLS_CA_FILE=/app/secrets/agent_ca.pem
REQUIRE_MTLS=1

# Optional: skip TLS server verification (same-stack Caddy internal TLS only; use MTLS_CA_FILE in prod)
# TLS_INSECURE_SKIP_VERIFY=1

# Optional: auto = discover by image (amnezia/awg); or comma-separated name prefixes
CONTAINER_FILTER=auto
INTERFACE_NAME=awg0
# CONTAINER_NAME=amnezia-awg

# Optional: intervals (seconds)
HEARTBEAT_INTERVAL_SECONDS=15
DESIRED_STATE_INTERVAL_SECONDS=15
RECONCILE_INTERVAL_SECONDS=30
HTTP_PORT=9105
