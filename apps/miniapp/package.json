{
  "name": "miniapp",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm exec vite",
    "build": "pnpm exec tsc --noEmit && pnpm exec vite build",
    "build:analyze": "ANALYZE=1 pnpm exec vite build",
    "analyze:top": "node scripts/analyze-bundle-top.mjs",
    "analyze": "pnpm run build:analyze && pnpm run analyze:top",
    "check:css-budget": "node scripts/check-css-budget.mjs",
    "build:ci": "pnpm run build && pnpm run check:css-budget",
    "design:check": "bash scripts/design-check.sh",
    "storybook:contract": "node scripts/check-storybook-contract.mjs",
    "storybook:page-stories": "node scripts/check-storybook-page-stories-location.mjs",
    "storybook:clear-cache": "bash scripts/clear-storybook-cache.sh",
    "storybook:taxonomy": "node scripts/check-storybook-taxonomy.mjs",
    "token:drift": "node scripts/check-token-drift.mjs",
    "lint": "pnpm exec eslint -c ../../eslint.config.js src --ext .ts,.tsx",
    "lint:fix": "pnpm exec eslint -c ../../eslint.config.js src --ext .ts,.tsx --fix",
    "typecheck": "pnpm exec tsc -b tsconfig.json --pretty false",
    "preview": "pnpm exec vite preview",
    "check:all": "pnpm run typecheck && pnpm run lint && pnpm run build:ci && pnpm run test:e2e",
    "test:e2e": "pnpm run build:ci && bash scripts/run-playwright-local.sh test",
    "test:visual": "pnpm run build:ci && bash scripts/run-playwright-local.sh test e2e/visual-regression.spec.ts",
    "test:e2e:dev": "PLAYWRIGHT_WEB_SERVER_MODE=dev bash scripts/run-playwright-local.sh test",
    "test:e2e:local": "bash scripts/run-playwright-local.sh test",
    "test:e2e:mock": "bash scripts/run-playwright-local.sh test e2e/mock-mirror-coverage.spec.ts e2e/mock-components-coverage.spec.ts e2e/mock-onboarding-coverage.spec.ts",
    "storybook": "pnpm exec storybook dev -p 6007 --exact-port",
    "build-storybook": "pnpm exec storybook build",
    "test-storybook": "node scripts/run-storybook-vitest.mjs",
    "test-storybook:official": "node scripts/run-storybook-test-runner.mjs",
    "storybook:ci": "pnpm run storybook:taxonomy && pnpm run storybook:page-stories && pnpm run storybook:contract && pnpm run build-storybook && pnpm run test-storybook",
    "chromatic": "pnpm exec chromatic",
    "test": "pnpm exec vitest run --project unit",
    "test:all": "pnpm exec vitest run",
    "test:watch": "pnpm exec vitest --project unit",
    "test:coverage": "pnpm exec vitest run --project unit --coverage",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run design:check && pnpm run test && pnpm run build:ci",
    "test:e2e:docker": "docker run --rm -t -e CI=1 -e PLAYWRIGHT_WEB_SERVER_MODE=preview -v \"$(pwd)/../..\":/work -w /work -v repo_node_modules:/work/node_modules mcr.microsoft.com/playwright:v1.58.2-noble bash -lc \"pnpm install --frozen-lockfile && pnpm run build:miniapp && cd apps/miniapp && pnpm exec playwright test\""
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@sentry/browser": "^8.55.0",
    "@tanstack/react-query": "^5.62.0",
    "@vpn-suite/shared": "workspace:*",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.487.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "1.58.2",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-links": "^10.3.1",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/react": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^28.1.0",
    "msw": "^2.11.5",
    "playwright": "^1.58.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.3.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.0.1",
    "vitest": "^4.0.18"
  }
}
