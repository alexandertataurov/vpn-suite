{
  "name": "@vpn-suite/shared",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "pnpm run build:types",
    "test": "echo 'No tests in shared'",
    "lint": "pnpm exec eslint -c ../../eslint.config.js src --ext .ts,.tsx",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "build:types": "pnpm exec tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "^2.2.4",
    "@grafana/faro-web-tracing": "^2.2.4",
    "clsx": "^2.1.1",
    "posthog-js": "^1.230.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "~5.9.3"
  }
}
