# syntax=docker/dockerfile:1
ARG PYTHON_IMAGE=python:3.12.8-slim
FROM ${PYTHON_IMAGE}
WORKDIR /app
RUN addgroup --system app && adduser --system --ingroup app app
COPY apps/telegram-bot/requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip \
    PIP_DISABLE_PIP_VERSION_CHECK=1 pip install --no-cache-dir -r requirements.txt pytest pytest-asyncio
COPY --chown=app:app apps/telegram-bot/ .
USER app
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1
CMD ["python", "-m", "pytest", "tests/", "-v"]
