{
  "name": "admin",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm exec vite",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' pnpm exec vite build",
    "lint": "pnpm exec eslint -c ../../eslint.config.js src --ext .ts,.tsx",
    "check:page-layout": "node scripts/check-page-layout.mjs",
    "typecheck": "pnpm exec tsc -b tsconfig.json --pretty false",
    "preview": "pnpm exec vite preview",
    "test:e2e": "pnpm run build && pnpm exec playwright test",
    "test:e2e:dev": "PLAYWRIGHT_WEB_SERVER_MODE=dev pnpm exec playwright test",
    "test:e2e:external": "PLAYWRIGHT_NO_WEBSERVER=1 pnpm exec playwright test",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "test": "pnpm exec vitest run --passWithNoTests",
    "storybook": "pnpm exec storybook dev -p 6006",
    "build-storybook": "pnpm exec storybook build",
    "storybook:test": "pnpm exec test-storybook --url http://127.0.0.1:6006 --includeTags smoke --excludeTags no-tests --testTimeout 60000 --maxWorkers 2",
    "storybook:guardrails": "node scripts/storybook-guardrails.mjs",
    "perf:lighthouse": "pnpm exec lighthouse http://127.0.0.1:4173/admin/ --output=html --output-path=../../docs/frontend/lighthouse-report.html --chrome-flags='--headless --no-sandbox' --only-categories=performance,accessibility --quiet",
    "perf:bundle": "pnpm run build"
  },
  "dependencies": {
    "@vpn-suite/shared": "workspace:*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "@sentry/react": "^8.55.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-virtual": "^3.13.18",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.487.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.49.0",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-links": "^10.2.17",
    "@storybook/react": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@storybook/test-runner": "^0.23.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "jsdom": "^28.1.0",
    "msw": "^2.11.5",
    "postcss": "^8.4.49",
    "prism-react-renderer": "^2.4.1",
    "prismjs": "^1.30.0",
    "storybook": "^10.2.17",
    "tailwindcss": "3.4.16",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.0.1",
    "vitest": "^4.0.18"
  }
}
