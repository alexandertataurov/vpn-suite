{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": ".cursor/hooks/session-context.sh" }
    ],
    "afterFileEdit": [
      { "command": "sh .cursor/hooks/after-edit.sh" }
    ],
    "beforeShellExecution": [
      { "command": "sh .cursor/hooks/before-shell.sh" }
    ],
    "beforeReadFile": [
      { "command": "sh .cursor/hooks/before-read.sh" }
    ],
    "stop": [
      { "command": "sh .cursor/hooks/stop.sh" }
    ]
  }
}
