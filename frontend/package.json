{
  "name": "vpn-suite-frontend",
  "private": true,
  "type": "module",
  "workspaces": [
    "admin",
    "miniapp",
    "shared"
  ],
  "scripts": {
    "dev:admin": "npm run dev -w admin",
    "dev:miniapp": "npm run dev -w miniapp",
    "build:shared": "npm run build --workspace=@vpn-suite/shared",
    "build:admin": "npm run build --workspace=admin",
    "build:miniapp": "npm run build --workspace=miniapp",
    "build": "npm run build:shared && npm run build:admin && npm run build:miniapp",
    "lint": "npm run lint -w admin && npm run lint -w miniapp",
    "typecheck": "npm run typecheck -w admin && npm run typecheck -w miniapp && npm run typecheck -w shared",
    "test": "npm run test -w admin && npm run test -w miniapp",
    "test:coverage": "npm run test:coverage -w admin && npm run test:coverage -w miniapp",
    "test:e2e": "npm run test:e2e -w admin",
    "test:e2e:ci": "npm run test:e2e:dev -w admin",
    "test:e2e:miniapp": "npm run test:e2e -w miniapp",
    "test:e2e:ui": "npm run test:e2e:ui -w admin",
    "e2e:admin": "npm run test:e2e -w admin",
    "e2e:miniapp": "npm run test:e2e -w miniapp",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "guardrails": "true",
    "storybook": "npm run storybook -w admin",
    "storybook:admin": "npm run storybook -w admin",
    "storybook:miniapp": "npm run storybook -w miniapp"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.17",
    "@storybook/addon-links": "^8.6.17",
    "@storybook/blocks": "^8.6.17",
    "@storybook/react": "^8.6.17",
    "@storybook/react-vite": "^8.6.17",
    "@storybook/test": "^8.6.17",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "storybook": "^8.6.17",
    "tailwind-merge": "^3.5.0",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7"
  },
  "dependencies": {
    "admin": "^1.4.1",
    "qrcode.react": "^4.2.0"
  }
}
