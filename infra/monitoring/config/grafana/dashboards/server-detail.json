{
  "title": "Server Detail",
  "uid": "server-detail",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "server_id",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(vpn_node_traffic_rx_bytes, server_id)",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Server RX Bytes",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "vpn_node_traffic_rx_bytes{server_id=\"$server_id\"}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Server TX Bytes",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "vpn_node_traffic_tx_bytes{server_id=\"$server_id\"}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Handshake Age (max)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "agent_last_handshake_max_age_seconds", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Peers Runtime",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "agent_peers_runtime", "refId": "A" }
      ]
    }
  ]
}
