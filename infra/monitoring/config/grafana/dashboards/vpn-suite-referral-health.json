{
  "title": "VPN Suite - Referral System Health",
  "uid": "vpn-suite-referral",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["vpn-suite", "observability"],
  "time": {"from": "now-7d", "to": "now"},
  "refresh": "5m",
  "panels": [
    {"type": "stat", "title": "Referral Signups (30d)", "gridPos": {"x": 0, "y": 0, "w": 6, "h": 3}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum(increase(vpn_revenue_referral_signup_total[30d]))", "refId": "A"}]},
    {"type": "stat", "title": "Referral Paid (30d)", "gridPos": {"x": 6, "y": 0, "w": 6, "h": 3}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum(increase(vpn_revenue_referral_paid_total[30d]))", "refId": "A"}]},
    {"type": "stat", "title": "Referral Attach Success (24h)", "gridPos": {"x": 12, "y": 0, "w": 6, "h": 3}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum(increase(referral_attach_total{status=\"attached\"}[24h]))", "refId": "A"}]},
    {"type": "stat", "title": "Referral Attach Fail (24h)", "gridPos": {"x": 18, "y": 0, "w": 6, "h": 3}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum(increase(referral_attach_fail_total[24h]))", "refId": "A"}]},
    {"type": "timeseries", "title": "Referral Signups / Paid Rate", "gridPos": {"x": 0, "y": 3, "w": 24, "h": 6}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum(rate(vpn_revenue_referral_signup_total[1h]))", "legendFormat": "Signups", "refId": "A"}, {"expr": "sum(rate(vpn_revenue_referral_paid_total[1h]))", "legendFormat": "Paid", "refId": "B"}]},
    {"type": "timeseries", "title": "Referral Attach Rate", "gridPos": {"x": 0, "y": 9, "w": 24, "h": 6}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "sum(rate(referral_attach_total[1h]))", "legendFormat": "Attached", "refId": "A"}, {"expr": "sum(rate(referral_attach_fail_total[1h]))", "legendFormat": "Failed", "refId": "B"}]}
  ]
}
